# Spotify OAuth (Authorization Code + PKCE; public client, no SPOTIFY_CLIENT_SECRET).
# Dashboard: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=

# Must match the Spotify app “Redirect URIs” entry exactly (scheme, host, port, path).
# Plain HTTP localhost example:
SPOTIFY_REDIRECT_URI=http://127.0.0.1:3000/api/auth/spotify/callback

# If you run `bun run dev`, Next enables `--experimental-https`. Use HTTPS in the Spotify
# dashboard and here, for example:
# SPOTIFY_REDIRECT_URI=https://127.0.0.1:3000/api/auth/spotify/callback

# 32+ random bytes recommended (encrypts oauth pending cookie + persisted token cookie).
PACELIST_SESSION_SECRET=
